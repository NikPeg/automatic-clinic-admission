# Copy this file to .env.local and fill in your token:
#   cp .env.example .env.local
# .env.local is read by Next.js and is git-ignored by convention.

# --- OpenRouter (all model calls go through OpenRouter) ---
# Get a key at https://openrouter.ai/keys  — paste it here.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Models (all via OpenRouter; swap freely, no code change).
# LLM brain — runs the intake conversation + structured extraction.
# Testing: latest DeepSeek (cheap). Switch to anthropic/claude-opus-4.8 for production.
OPENROUTER_LLM_MODEL=deepseek/deepseek-v4-pro
# Speech-to-text — transcribes the patient's voice  (/api/v1/audio/transcriptions).
OPENROUTER_STT_MODEL=openai/gpt-4o-transcribe
# Text-to-speech — the assistant's spoken voice  (/api/v1/audio/speech).
OPENROUTER_TTS_MODEL=google/gemini-3.1-flash-tts-preview
# TTS voice id (Gemini TTS voices: Kore, Puck, Charon, Aoede, Zephyr, ...).
OPENROUTER_TTS_VOICE=Kore

# Optional attribution headers recommended by OpenRouter.
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_TITLE=Clinic Intake Assistant

# --- App ---
NEXT_PUBLIC_APP_NAME=Clinic Intake Assistant
